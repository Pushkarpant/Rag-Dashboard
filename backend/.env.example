# .env — fill in your real keys, NEVER commit this file

# Gemini (free at ai.google.dev)
GEMINI_API_KEY=your-gemini-api-key-here

# Pinecone (free tier at pinecone.io)
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX_NAME=rag-documents

# JWT — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=paste-64-char-hex-string-here

# PostgreSQL — user/auth/chat database (REQUIRED; the app will not start without it).
# Local dev (Docker):  postgresql+psycopg://rag_user:rag_pass@localhost:5433/rag_dashboard
# Production (managed): postgresql+psycopg://USER:PASS@HOST:5432/DB?sslmode=require
DATABASE_URL=postgresql+psycopg://rag_user:rag_pass@localhost:5433/rag_dashboard

# Cohere Rerank (free trial key at dashboard.cohere.com). Reorders Pinecone
# candidates with a cross-encoder. If empty, the app falls back to Pinecone order.
COHERE_API_KEY=your-cohere-key-here

# Pinecone index settings:
#   Name:       rag-documents
#   Dimensions: 3072  ← MUST be 3072 (native gemini-embedding-001 output)
#   Metric:     cosine
#   Cloud/Region: AWS / us-east-1

# Groq (generation). Key from https://console.groq.com
GROQ_API_KEY=your-groq-key
